# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Required.
#   Local dev (docker compose up -d db):
#     DATABASE_URL="postgresql://hbario:hbario@localhost:5432/hbario"
#   Render: use the *internal* connection string from your Postgres dashboard.
DATABASE_URL="postgresql://hbario:hbario@localhost:5432/hbario"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Change this to a long random string in production.
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# ─── Hedera / WalletConnect ──────────────────────────────────────────────────
# Required for the wallet connect modal. Get a free project ID at
# https://cloud.reown.com (formerly WalletConnect Cloud).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Which network the UI defaults to on first load. Users can toggle this at
# runtime on the /wallet page. Production deploys default to mainnet so
# first-time visitors match the network their HashPack is most likely on.
NEXT_PUBLIC_DEFAULT_NETWORK="mainnet" # testnet | mainnet

# ─── Hedera Treasury Accounts (workflow unlock fees) ─────────────────────────
# These accounts receive HBAR payments when users unlock workflows for
# execution. The verify route picks the right one based on the order's
# network.
HEDERA_TREASURY_ACCOUNT_ID_TESTNET="0.0.1234567"
HEDERA_TREASURY_ACCOUNT_ID_MAINNET="0.0.0000000"

# Backwards-compatible fallback used when the per-network variant above is
# not set. Safe to leave commented out in production.
# HEDERA_TREASURY_ACCOUNT_ID="0.0.1234567"

# ─── Hedera Treasury Accounts (AI planning fees) ─────────────────────────────
# Receives HBAR per chat message — separate from workflow unlock fees so
# you can do cleaner accounting. Falls back to HEDERA_TREASURY_ACCOUNT_ID
# if unset.
HEDERA_AI_TREASURY_ACCOUNT_ID="0.0.0000000"
# Optional per-network overrides:
# HEDERA_AI_TREASURY_ACCOUNT_ID_TESTNET=""
# HEDERA_AI_TREASURY_ACCOUNT_ID_MAINNET=""

# ─── Server-side AI Provider ─────────────────────────────────────────────────
# The chat agent runs LLM calls server-side using THIS key. Users never see
# or supply an AI provider key — they pay per chat message in HBAR.
#
# Pick Anthropic (recommended default) or OpenAI:
AI_PROVIDER="anthropic"                         # "anthropic" | "openai" | "custom"
ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""                             # used when AI_PROVIDER=openai
# AI_API_KEY=""                                 # used when AI_PROVIDER=custom (OpenAI-compatible base)
# AI_API_BASE=""                                # override base URL if needed
AI_MODEL="claude-sonnet-4-5"                    # see below for alternatives
#
# Model options:
#   Anthropic (great instruction-following, strong JSON discipline):
#     claude-sonnet-4-5     — mid-tier flagship; best balance for this workload (default)
#     claude-haiku-4-5      — smallest + cheapest; fine for simpler prompts
#     claude-opus-4-5       — overkill for JSON planning, expensive
#   OpenAI:
#     gpt-4o-mini           — cheapest sensible OpenAI option
#     gpt-4o                — upgrade pick

# ─── AI Pricing Knobs ────────────────────────────────────────────────────────
# All in USD per 1K tokens. The defaults the server uses match gpt-4o-mini;
# if you switch to Anthropic Sonnet 4.5 you MUST set these or you'll
# under-quote and lose money per call.
#
# Anthropic claude-sonnet-4-5 retail pricing ($3 / $15 per 1M tokens):
AI_INPUT_USD_PER_1K="0.003"
AI_OUTPUT_USD_PER_1K="0.015"
#
# Anthropic claude-haiku-4-5 retail pricing ($1 / $5 per 1M tokens):
# AI_INPUT_USD_PER_1K="0.001"
# AI_OUTPUT_USD_PER_1K="0.005"
#
# OpenAI gpt-4o-mini retail pricing ($0.15 / $0.60 per 1M tokens):
# AI_INPUT_USD_PER_1K="0.00015"
# AI_OUTPUT_USD_PER_1K="0.0006"

# Hard cap on the LLM's response size, in tokens.
# AI_MAX_OUTPUT_TOKENS="2048"
# Flat platform fee per call, in USD.
# AI_SERVICE_FEE_USD="0.02"
# Multiplier applied to the HBAR amount to absorb price drift between quote
# and pay-time. 1.10 = 10% over-quote.
# AI_SLIPPAGE_BUFFER="1.10"
# Min/max bounds on a single quote so a bad price feed or runaway prompt
# can't quote a nonsense amount.
# AI_MIN_QUOTE_HBAR="0.05"
# AI_MAX_QUOTE_HBAR="5"
# How long a quote remains payable, in milliseconds.
# AI_QUOTE_TTL_MS="80000"

# ─── HBAR Price Feed ─────────────────────────────────────────────────────────
# We use CoinGecko's free /simple/price endpoint and cache for 60s. If that
# request fails this value is used so the app stays available.
# HBAR_USD_FALLBACK="0.08"

# ─── Payments MCP Server ─────────────────────────────────────────────────────
# Public base URL the MCP server reports in its capabilities responses
# (e.g. for the /agent.json manifest and the /mcp settings page).
#
# Set this to the externally-reachable URL of your deployment so that the
# endpoint shown on the /mcp page is the one remote agents (Claude Desktop
# on another machine, etc.) can actually hit. If unset, /api/mcp/key falls
# back to the request's origin, which is fine for production behind a clean
# proxy but useless for local dev when the agent isn't on the same machine.
MCP_PUBLIC_BASE_URL="https://hbario.com"

