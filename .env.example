# Database
# For production, use a PostgreSQL database (e.g., Vercel Postgres, Railway, Supabase)
# For demo/testing, SQLite works: file:./dev.db
DATABASE_URL="file:./dev.db"

# JWT Secret - CHANGE THIS IN PRODUCTION
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# Hedera Treasury Account (receives HBAR payments for workflow unlocks)
HEDERA_TREASURY_ACCOUNT_ID="0.0.1234567"
