// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WorkflowStatus {
  draft
  awaiting_payment
  unlocked
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  awaiting_payment
  paid
  failed
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  /// Per-user API key for the Hedera Payments MCP server. Optional —
  /// generated lazily the first time the user opens the MCP page. External
  /// agents (Claude Desktop, Cline, etc.) include this in the Authorization
  /// header to act on this user's behalf when calling our MCP endpoint.
  mcpApiKey     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workflows     Workflow[]
  orders        Order[]
  payments      Payment[]
  receipts      Receipt[]
}

model Workflow {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  title         String
  type          String
  prompt        String?
  summary       String?
  workflowJson  String?        // JSON stored as text
  status        WorkflowStatus @default(draft)
  paymentStatus PaymentStatus  @default(unpaid)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  orders        Order[]
  payments      Payment[]
  receipts      Receipt[]

  @@index([userId])
}

model Order {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id])
  amountHbar      Float
  recipientAccount String
  memo            String?
  status          String    @default("pending")
  transactionId   String?
  /** Hedera network the order was created on: "testnet" | "mainnet". */
  network         String    @default("testnet")
  /**
   * What this order pays for.
   *   "workflow_unlock" — legacy 1 HBAR per-workflow unlock fee.
   *   "ai_planning"     — pays for the LLM call that generates a workflow.
   */
  kind            String    @default("workflow_unlock")
  /** USD value the quote was calculated against (server-side bookkeeping). */
  quoteUsd        Float?
  /** HBAR/USD rate snapshot at quote time, for audit + later refund math. */
  hbarUsdRate     Float?
  /** When an ai_planning order was redeemed against an LLM call. */
  consumedAt      DateTime?
  /** When the quote stops being valid. After this the order is dead. */
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt


  payments        Payment[]
  receipts        Receipt[]

  @@index([userId])
  @@index([workflowId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  workflowId      String
  workflow        Workflow      @relation(fields: [workflowId], references: [id])
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  payerAccount    String
  recipientAccount String
  amountHbar      Float
  memo            String?
  transactionId   String?
  status          PaymentStatus @default(unpaid)
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())

  receipts        Receipt[]

  @@index([userId])
  @@index([workflowId])
  @@index([orderId])
}

model Receipt {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  workflowId       String
  workflow         Workflow  @relation(fields: [workflowId], references: [id])
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id])
  paymentId        String?
  payment          Payment?  @relation(fields: [paymentId], references: [id])
  transactionId    String
  amountHbar       Float
  payerAccount     String
  recipientAccount String
  memo             String?
  workflowType     String
  receiptJson      String?   // JSON stored as text
  /// For compound workflows, the 0-based index of the step this receipt belongs to.
  /// NULL on legacy single-step receipts (treated as step 0 implicitly).
  stepIndex        Int?
  /// Discriminator for the step kind ("single_payment" | "bulk_payout" | ...),
  /// duplicated here so the UI can render step rows without re-parsing workflowJson.
  stepKind         String?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([workflowId])
  @@index([orderId])
  @@index([paymentId])
  @@index([workflowId, stepIndex])
}

// ─── Global Config & Project Overrides ────────────────────────────────────────

model AppConfig {
  id        String   @id @default("global")
  provider  String   @default("custom")
  apiBase   String   @default("")
  apiKey    String   @default("")
  model     String   @default("")
  maxTokens Int?
  updatedAt DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Override fields (null = inherit from AppConfig)
  provider  String?
  apiBase   String?
  apiKey    String?
  model     String?
  maxTokens Int?
}
